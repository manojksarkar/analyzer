  "clang": {
    "llvmLibPath": "C:\\Program Files\\LLVM\\bin\\libclang.dll",
    "clangIncludePath": "C:\\Program Files\\LLVM\\lib\\clang\\17\\include",
    "clangArgs": []
    // Linux (uncomment and replace above, or use config.local.json):
    // "llvmLibPath": "/usr/lib/llvm-17/lib/libclang.so",
    // "clangIncludePath": "/usr/lib/llvm-17/include"
  },
  "llm": {
    "descriptions": false,
    "baseUrl": "http://localhost:11434",
    "defaultModel": "llama3.2",
    "timeoutSeconds": 60,
    "abbreviationsPath": "config/abbreviations.txt"
  },
  // Optional: logical groups of modules. Each group key maps to a full
  // "modules" mapping (module name -> folder or list of folders, relative
  // to the parsed C++ project base). When "selectedGroup" is set to one of
  // these keys, only that group's modules are parsed; other files are ignored.
  // If "selectedGroup" is empty or missing, the default behaviour is used
  // (either top-level "modules" mapping if present, or first-folder = module).
  //
  // Example:
  // "modulesGroups": {
  //   "group1": {
  //     "core": ["app", "math"],
  //     "support": "outer/inner",
  //     "tests_a": ["tests/direction", "tests/enum", "tests/flow"],
  //     "tests_b": ["tests/hub", "tests/poly", "tests/structs"]
  //   },
  //   "group2": {
  //     "core": ["app"],
  //     "tests_b": ["tests/hub"]
  //   }
  // },
  //
  // "selectedGroup": "group1",
  "selectedGroup": "group1",
  "modulesGroups": {
    "group1": {
      "core": [
        "app",
        "math"
      ],
      "support": "outer/inner",
      "tests_a": [
        "tests/direction",
        "tests/enum",
        "tests/flow"
      ],
      "tests_b": [
        "tests/hub",
        "tests/poly",
        "tests/structs"
      ]
    },
    "group2": {
      "core": [
        "app",
        "math"
      ],
      "support": "outer/inner"
    }
  },
  "export": {
    "docxPath": "output/software_detailed_design_{group}.docx",
    "docxFontSize": 8
  }
}
