# Base URL of the ASPICE API server (FastAPI). Includes the /api/v1 prefix.
# Falls back to this value if unset.
#
# For local dev this points at the MOCK backend in ../../mock-api
#   (cd ../mock-api && uvicorn api.main:app --port 8000).
# Switch to the REAL API (../../api, developed separately) with NO code change:
#   run it on this same URL, or set VITE_API_URL to wherever it's hosted.
VITE_API_URL=http://localhost:8000/api/v1

# How diagram assets (image_url from the render payload) are loaded. The API
# returns a relative path/key, not a ready link; the UI builds the URL in
# resolveAssetUrl (src/services/mappers/document.ts).
#  - UNSET (default): the ref is a path under the base → ${VITE_API_URL}/<path>
#    (the mock's REST asset route).
#  - SET to a dedicated endpoint (e.g. /assets): the path is passed as a query →
#    ${VITE_API_URL}/assets?path=<path>  (the real-API model).
# The endpoint must serve the bytes without a Bearer header (an <img> can't send
# one; the query carries the path, never a token).
# VITE_ASSET_ENDPOINT=/assets
